# Ignore everything by default
*

# Include only CONJECTURE_III folder and its contents
!CONJECTURE_III/
!CONJECTURE_III/**

# Include CONJECTURE_IV folder and its contents
!CONJECTURE_IV/
!CONJECTURE_IV/**

# Include CONJECTURE_V folder and its contents
!CONJECTURE_V/
!CONJECTURE_V/**

# Include BETA_PRECISION folder and its contents
!BETA_PRECISION/
!BETA_PRECISION/**

# Include TEST_SUITE folder and its contents
!TEST_SUITE/
!TEST_SUITE/**

# Include FORMAL_PROOF_NEW folder and its contents
!FORMAL_PROOF_NEW/
!FORMAL_PROOF_NEW/**

# But exclude Python cache files and OS files everywhere
__pycache__/
*.pyc
*.pyo
.DS_Store

# Include the specific image file
!RH_SINGULARITY_OG.png

# Include the HTML visualization
!RH_SINGULARITY.html

# Include index page
!index.html

# Keep .gitignore itself
!.gitignore

# Keep README if you want to add one
!README.md